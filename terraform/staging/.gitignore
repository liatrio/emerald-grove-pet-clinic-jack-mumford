# Local .terraform directories
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform lock file (can be committed, but excluding for now)
.terraform.lock.hcl

# Terraform variable files that may contain sensitive data
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Crash log files
crash.log
crash.*.log

# Backup files
*.backup
